{
  "name": "dagshund",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx @tailwindcss/cli -i src/styles/index.css -o src/styles/output.css --watch & bun --hot src/index.ts",
    "build:css": "bunx @tailwindcss/cli -i src/styles/index.css -o src/styles/output.css --minify",
    "build": "rm -rf dist && bun run build:css && bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "build:template": "bun scripts/build-template.ts"
  },
  "dependencies": {
    "@xyflow/react": "12.10.0",
    "elkjs": "0.11.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "yaml": "2.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@tailwindcss/cli": "4.1.18",
    "@types/bun": "1.3.8",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3"
  }
}
